  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\u0427\u0435\u043B\u043E\u0432\u0435\u0447\u0435\u0441\u0442\u0432\u043E
    \u043F\u0440\u043E\u0434\u0435\u043B\u0430\u043B\u043E \u0431\u043E\u043B\u044C\u0448\u043E\u0439
    \u043F\u0443\u0442\u044C \u0441\u043A\u0432\u043E\u0437\u044C \u044D\u043F\u043E\u0445\u0438,
    \u043D\u0430\u0441\u043B\u0435\u0434\u0443\u044F \u0437\u043D\u0430\u043D\u0438\u044F
    \u043F\u0440\u0435\u0434\u043A\u043E\u0432. \u041A\u0430\u0436\u0434\u044B\u0439
    \u0447\u0435\u043B\u043E\u0432\u0435\u043A - \u0433\u043B\u0430\u0432\u043D\u044B\u0439
    \u0433\u0435\u0440\u043E\u0439 \u0441\u0432\u043E\u0435\u0439 \u0436\u0438\u0437\u043D\u0438,
    \u0432\u0435\u0434\u044C \u0438\u043C\u0435\u043D\u043D\u043E \u043E\u0442 \u043D\u0435\u0433\u043E
    \u0437\u0430\u0432\u0438\u0441\u0438\u0442, \u0447\u0442\u043E \u043E\u043D \u043E\u0431\u0440\u0435\u0442\u0435\u0442
    \u0437\u0430 \u0441\u0432\u043E\u044E \u0436\u0438\u0437\u043D\u044C. \u0412
    \u043D\u0430\u0448\u0435\u0439 \u0438\u0433\u0440\u0435 \u0433\u043B\u0430\u0432\u043D\u044B\u0439
    \u0433\u0435\u0440\u043E\u0439 - \u043D\u0435 \u043E\u0434\u0438\u043D \u0447\u0435\u043B\u043E\u0432\u0435\u043A,
    \u0430 \u0432\u0441\u0435 \u0447\u0435\u043B\u043E\u0432\u0435\u0447\u0435\u0441\u0442\u0432\u043E,
    \u043A\u043E\u0442\u043E\u0440\u043E\u0435 \u043F\u0443\u0442\u0435\u0448\u0435\u0441\u0442\u0432\u0443\u0435\u0442
    \u0447\u0435\u0440\u0435\u0437 \u0432\u0435\u043A\u0430, \u043F\u0440\u0438\u043E\u0431\u0440\u0435\u0442\u0430\u044F
    \u0438 \u043E\u0431\u0443\u0447\u0430\u044F\u0441\u044C."
  m_isRightToLeft: 0
